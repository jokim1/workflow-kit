{
  "name": "pipelane",
  "version": "0.2.0",
  "type": "module",
  "description": "Pipelane — release cockpit for AI vibe coders.",
  "bin": {
    "pipelane": "./bin/pipelane"
  },
  "files": [
    "bin",
    "dist",
    "templates",
    "docs/RELEASE_WORKFLOW.md",
    "docs/PIPELANE_BOARD.md",
    "docs/PIPELANE_API.md",
    "README.md"
  ],
  "scripts": {
    "test": "node --test test/pipelane.test.mjs",
    "smoke": "node ./src/cli.ts --help",
    "dashboard": "node ./src/cli.ts dashboard",
    "board": "node ./src/cli.ts board",
    "build": "tsc -p tsconfig.build.json && node -e \"import('node:fs').then(m=>m.cpSync('src/dashboard/public','dist/dashboard/public',{recursive:true}))\"",
    "prepare": "npm run build",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.9.3"
  }
}
