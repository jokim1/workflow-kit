#!/usr/bin/env node
// Launcher for the Pipelane CLI.
//
// Prefer the compiled `dist/cli.js` when present (how consumers see it
// after `npm install`). Fall back to `src/cli.ts` for in-repo development
// where `npm run build` hasn't been run yet.
//
// Node's `import.meta.url` reports this script's real file URL (after
// symlink resolution), so the relative lookups below work identically
// whether the bin is invoked from a worktree, an installed package in
// node_modules, or via `npx`.
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

const distUrl = new URL('../dist/cli.js', import.meta.url);
const srcUrl = new URL('../src/cli.ts', import.meta.url);
const target = existsSync(fileURLToPath(distUrl)) ? distUrl : srcUrl;

await import(target.href);
